@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.PageTitle = "Campaigns";
    ViewBag.ActiveNav = "promotions";
}

@section Styles {
<link rel="stylesheet" href="~/css/admin/promotions.css" asp-append-version="true" />
}

<header class="d-flex justify-content-between align-items-center mb-5 animate-up">
    <div>
        <h4 class="fw-bold mb-1" style="color:var(--navy-dark);">Campaigns</h4>
        <p class="text-muted small mb-0 fw-medium">Manage premium promotions and customer rewards.</p>
    </div>
    <button class="app-btn-primary w-auto px-4 shadow-none"
            style="font-size:0.8rem;border-radius:12px;"
            data-bs-toggle="modal" data-bs-target="#promoModal">
        <i class="fas fa-plus me-2"></i> NEW CAMPAIGN
    </button>
</header>

<!-- ── Campaign Cards Grid ───────────────────────────────── -->
<div class="row g-4" id="campaigns-grid">
    <!-- Rendered by promotions.js -->
</div>

<!-- ── Create Promo Modal ────────────────────────────────── -->
<div class="modal fade" id="promoModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 overflow-hidden" style="border-radius:24px;">
            <div class="modal-header text-white border-0 px-4 pt-4" style="background:var(--navy-dark);">
                <h6 class="fw-bold mb-0" style="color:var(--cyan-electric);">CREATE NEW CAMPAIGN</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-muted">CAMPAIGN NAME</label>
                        <input type="text" id="promo-name" class="form-control bg-light border-0 py-2"
                               placeholder="e.g. VIP Summer Wash Discount" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-muted">TARGET MEMBER TIER</label>
                        <select id="promo-target" class="form-select bg-light border-0 py-2">
                            <option value="All Customers">All Customers</option>
                            <option value="Platinum">Platinum</option>
                            <option value="Gold">Gold</option>
                            <option value="Silver">Silver</option>
                            <option value="Standard Member">Standard Member</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-muted">MAX REDEMPTIONS</label>
                        <input type="number" id="promo-max" class="form-control bg-light border-0 py-2" value="500" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold text-muted">DESCRIPTION & TERMS</label>
                        <textarea id="promo-desc" class="form-control bg-light border-0 py-2" rows="3"
                                  placeholder="Enter description..."></textarea>
                    </div>
                </div>
            </div>
            <div class="p-4 pt-0">
                <button type="button" class="app-btn-primary shadow-none py-3"
                        onclick="launchCampaign()" data-bs-dismiss="modal">LAUNCH CAMPAIGN</button>
                <button type="button" class="btn btn-link text-muted w-100 mt-2 text-decoration-none small fw-bold"
                        data-bs-dismiss="modal">CANCEL</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/promotions.js"></script>
}
