@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.PageTitle = "Live Queue Management";
    ViewBag.ActiveNav = "queue";
}

@section Styles {
<link rel="stylesheet" href="~/css/admin/queue.css" asp-append-version="true" />
}

<header class="d-flex justify-content-between align-items-center mb-5 animate-up">
    <div>
        <h4 class="fw-bold mb-1" style="color:var(--navy-dark);">Live Queue Management</h4>
        <p class="text-muted small mb-0 fw-medium">Theo dõi hàng đợi xe, cập nhật trạng thái hoạt động và thanh toán check-out.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-sm bg-white border shadow-sm px-3 fw-bold"
                style="border-radius:12px;font-size:0.82rem;" onclick="loadQueue()">
            <i class="fas fa-sync-alt me-1 text-muted"></i>Làm mới
        </button>
        <button class="app-btn-primary py-2 px-4 w-auto shadow-none"
                style="font-size:0.82rem;border-radius:12px;"
                data-bs-toggle="modal" data-bs-target="#lprScannerModal"
                onclick="startScanner()">
            <i class="fas fa-camera me-1"></i>QUÉT LPR
        </button>
    </div>
</header>

<!-- Priority Info Banner -->
<div class="d-flex align-items-center mb-4 py-3 px-4 animate-up"
     style="background:#0b1121;color:#ffffff;border-radius:16px;animation-delay:0.05s;">
    <i class="fas fa-info-circle fa-lg me-3" style="color:#0ea5e9;flex-shrink:0;"></i>
    <div class="small fw-medium">
        Hàng đợi AutoWash Pro tự động sắp xếp theo thứ tự ưu tiên:
        <span class="fw-bold" style="color:#0ea5e9;">PLATINUM</span> &gt;
        <span class="fw-bold" style="color:#ffcf33;">GOLD</span> &gt;
        <span class="fw-bold" style="color:#94a3b8;">SILVER</span>.
        Các xe cùng hạng được sắp xếp theo thời gian đặt lịch.
    </div>
</div>

<!-- ── Filters ───────────────────────────────────────────── -->
<div class="row g-3 mb-5 animate-up" style="animation-delay:0.1s;">
    <div class="col-md-7">
        <div class="input-group shadow-sm" style="border-radius:14px;overflow:hidden;">
            <span class="input-group-text bg-white border-0 ps-3 text-muted"><i class="fas fa-search"></i></span>
            <input type="text" id="queue-search" class="form-control bg-white border-0 py-3 ps-2"
                   placeholder="Tìm theo tên khách hàng, biển số xe, tên gói..."
                   oninput="filterQueue()" style="outline:none;box-shadow:none;" />
        </div>
    </div>
    <div class="col-md-5">
        <div class="d-flex flex-wrap gap-2">
            <button onclick="setQueueFilter('ALL')" id="qf-ALL" class="queue-filter-btn active">
                Tất cả <span class="filter-count" id="cnt-ALL">0</span>
            </button>
            <button onclick="setQueueFilter('Waiting')" id="qf-Waiting" class="queue-filter-btn">
                Đang chờ <span class="filter-count" id="cnt-Waiting">0</span>
            </button>
            <button onclick="setQueueFilter('Active')" id="qf-Active" class="queue-filter-btn">
                Đang xử lý <span class="filter-count" id="cnt-Active">0</span>
            </button>
            <button onclick="setQueueFilter('Completed')" id="qf-Completed" class="queue-filter-btn">
                Hoàn tất <span class="filter-count" id="cnt-Completed">0</span>
            </button>
        </div>
    </div>
</div>

<!-- ── Queue Table ───────────────────────────────────────── -->
<div class="app-card p-0 overflow-hidden border-0 shadow-lg animate-up" style="animation-delay:0.15s;border-radius:24px;">
    <div class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0" style="color:var(--navy-dark);">Danh sách xe trong hàng đợi</h6>
        <span class="badge rounded-pill px-3 py-2 fw-bold" id="queue-count-badge"
              style="background:var(--navy-dark);color:var(--cyan-electric);font-size:0.7rem;">
            Đang tải...
        </span>
    </div>

    <!-- Empty state -->
    <div id="queue-empty-state" class="p-5 text-center text-muted" style="display:none;">
        <i class="fas fa-car-side fa-3x mb-3 opacity-25"></i>
        <div class="fw-bold fs-6">Hàng đợi đang trống</div>
        <small class="d-block text-muted mt-1">Không tìm thấy phương tiện nào khớp với bộ lọc hiện tại.</small>
    </div>

    <!-- Table -->
    <div class="table-responsive" id="queue-table-wrapper">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr class="small text-uppercase text-muted" style="letter-spacing:0.5px;">
                    <th class="ps-4 py-3">#</th>
                    <th>Khách hàng</th>
                    <th>Biển số xe</th>
                    <th>Hạng</th>
                    <th>Trạng thái</th>
                    <th>Dịch vụ</th>
                    <th>Tổng tiền</th>
                    <th class="text-end pe-4">Hành động</th>
                </tr>
            </thead>
            <tbody class="small fw-medium" id="queue-tbody">
                <!-- Rendered by queue.js -->
            </tbody>
        </table>
    </div>
</div>

<!-- ── LPR Scanner Modal ─────────────────────────────────── -->
<div class="modal fade" id="lprScannerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 overflow-hidden text-white" style="border-radius:24px;background:var(--navy-dark);">
            <div class="modal-header border-0 px-4 pt-4">
                <h6 class="fw-bold mb-0" style="color:var(--cyan-electric);">
                    <i class="fas fa-camera me-2"></i>MÔ PHỎNG CAMERA QUÉT LPR
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        onclick="resetScanner()"></button>
            </div>
            <div class="modal-body p-4">
                <div class="scanner-viewport" id="lpr-viewport">
                    <div class="scanner-grid"></div>
                    <div class="scanner-reticle reticle-tl"></div>
                    <div class="scanner-reticle reticle-tr"></div>
                    <div class="scanner-reticle reticle-bl"></div>
                    <div class="scanner-reticle reticle-br"></div>
                    <div class="scanner-line" id="lpr-scan-line" style="display:none;"></div>
                    <div class="scanner-overlay-text" id="lpr-scanning-text" style="display:none;">
                        <i class="fas fa-spinner fa-spin me-2"></i>ĐANG QUÉT LPR BIỂN SỐ...
                    </div>
                    <div class="scanner-plate-box" id="lpr-plate-result" style="display:none;"></div>
                    <div class="scanner-overlay-text text-success" id="lpr-success-text"
                         style="display:none;background:rgba(6,78,59,0.9);border-color:#10b981;">
                        <i class="fas fa-check-circle me-2"></i>NHẬN DIỆN THÀNH CÔNG!
                    </div>
                </div>
            </div>
            <div class="p-4 pt-0">
                <button type="button" id="lpr-add-btn" class="app-btn-primary shadow-none py-3" style="display:none;"
                        onclick="addScannedToQueue()" data-bs-dismiss="modal">
                    ĐƯA VÀO HÀNG ĐỢI
                </button>
                <button type="button" id="lpr-waiting-btn"
                        class="btn btn-secondary w-100 py-3 text-white border-0 fw-bold" disabled
                        style="border-radius:14px;opacity:0.5;">
                    ĐANG QUÉT LPR VUI LÒNG ĐỢI...
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Manage Services Modal ─────────────────────────────── -->
<div class="modal fade" id="manageServicesModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 overflow-hidden" style="border-radius:24px;">
            <div class="modal-header text-white border-0 px-4 pt-4" style="background:var(--navy-dark);">
                <h6 class="fw-bold mb-0" style="color:var(--cyan-electric);">
                    <i class="fas fa-tasks me-2"></i>CHI TIẾT VÀ TIẾN TRÌNH DỊCH VỤ XE
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="manage-modal-body">
                <!-- Rendered by queue.js -->
            </div>
            <div class="p-4 pt-0 d-flex gap-2">
                <button type="button" class="app-btn-primary shadow-none py-3"
                        onclick="saveQueueUpdate()" data-bs-dismiss="modal">LƯU THAY ĐỔI</button>
                <button type="button" class="btn btn-light w-100 py-3 text-muted border-0 fw-bold"
                        style="border-radius:14px;" data-bs-dismiss="modal">HỦY BỎ</button>
            </div>
        </div>
    </div>
</div>

<!-- ── Checkout Modal ────────────────────────────────────── -->
<div class="modal fade" id="checkoutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 overflow-hidden" style="border-radius:24px;">
            <div class="modal-header text-white border-0 px-4 pt-4" style="background:var(--navy-dark);">
                <h6 class="fw-bold mb-0" style="color:var(--cyan-electric);">XÁC NHẬN THANH TOÁN & CHECK-OUT</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="checkout-modal-body">
                <!-- Rendered by queue.js -->
            </div>
            <div class="p-4 pt-0">
                <button type="button" class="app-btn-primary shadow-none py-3"
                        onclick="checkoutComplete()" data-bs-dismiss="modal">
                    HOÀN TẤT & CHECK-OUT
                </button>
                <button type="button" class="btn btn-link text-muted w-100 mt-2 text-decoration-none small fw-bold"
                        data-bs-dismiss="modal">HỦY BỎ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/queue.js" asp-append-version="true"></script>
}
