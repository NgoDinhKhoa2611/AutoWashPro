@* _AdminLayout.cshtml — Layout bọc ngoài tất cả trang Admin
   Sử dụng: @{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
   ViewBag.ActiveNav: "dashboard"|"queue"|"customers"|"services"|"promotions"
*@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.PageTitle ?? "Admin") — AutoWash Pro Console</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/shared.css" />
    <link rel="stylesheet" href="~/css/admin/admin.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div id="toast-container"></div>

<!-- Confirm Modal -->
<div id="confirm-modal-backdrop" class="confirm-modal-backdrop" style="display:none;">
    <div class="confirm-modal-card animate-confirm-in">
        <div class="confirm-modal-header">
            <h5 class="confirm-modal-title" id="confirm-modal-title">Xác nhận</h5>
            <button type="button" class="confirm-modal-close-btn" onclick="window.closeConfirm()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="confirm-modal-body" id="confirm-modal-body">Bạn có chắc chắn không?</div>
        <div class="confirm-modal-footer">
            <button class="confirm-cancel-btn" onclick="window.closeConfirm()">HỦY</button>
            <button class="confirm-ok-btn confirm-btn-danger" id="confirm-ok-btn">XÁC NHẬN</button>
        </div>
    </div>
</div>

<div class="admin-wrapper">

    <!-- ── Admin Sidebar ──────────────────────────────────── -->
    <nav id="sidebar">
        <a href="/Admin/Dashboard" class="text-decoration-none d-block p-4 mb-4 hover-opacity" style="transition: opacity 0.2s; cursor: pointer;">
            <div class="brand-full">
                <h4 class="fw-bold mb-0 text-dark">AutoWash <span class="text-cyan">Pro</span></h4>
                <small class="text-muted fw-bold"
                       style="font-size:0.65rem;letter-spacing:1.5px;text-transform:uppercase;">
                    Premium Console
                </small>
            </div>
            <div class="admin-brand-mini" id="sidebar-brand-mini">
                <i class="fas fa-shield-halved text-dark fa-lg"></i>
            </div>
        </a>

        <div style="flex:1;">
            <a href="/Admin/Dashboard"
               class="sidebar-link @(ViewBag.ActiveNav=="dashboard" ? "active" : "")">
                <i class="fas fa-chart-line"></i> <span>Dashboard</span>
            </a>
            <a href="/Admin/Queue"
               class="sidebar-link @(ViewBag.ActiveNav=="queue" ? "active" : "")">
                <i class="fas fa-list-ol"></i> <span>Live Queue</span>
            </a>
            <a href="/Admin/Customers"
               class="sidebar-link @(ViewBag.ActiveNav=="customers" ? "active" : "")">
                <i class="fas fa-users"></i> <span>Customers</span>
            </a>
            <a href="/Admin/Services"
               class="sidebar-link @(ViewBag.ActiveNav=="services" ? "active" : "")">
                <i class="fas fa-box"></i> <span>Services</span>
            </a>
            <a href="/Admin/Promotions"
               class="sidebar-link @(ViewBag.ActiveNav=="promotions" ? "active" : "")">
                <i class="fas fa-tags"></i> <span>Promotions</span>
            </a>
            <hr class="mx-3 opacity-10 my-4" />
            <a href="/Account/Logout"
               class="sidebar-link text-danger opacity-75"
               onclick="return confirm('Bạn có chắc muốn đăng xuất?')">
                <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
            </a>
        </div>

        <div class="p-3">
            <button class="sidebar-collapse-btn" onclick="toggleAdminSidebar()">
                <i class="fas fa-chevron-left"></i>
                <span>Collapse menu</span>
            </button>
        </div>
    </nav>

    <!-- ── Admin Main ─────────────────────────────────────── -->
    <div class="admin-main" id="admin-main">
        @RenderBody()
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/app.js"></script>
<script src="~/js/admin-layout.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
