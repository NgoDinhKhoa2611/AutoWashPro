@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewBag.PageTitle = "Hồ sơ cá nhân";
    ViewBag.ActiveNav = "profile";
}

<div class="container-fluid p-0">

    <!-- ── Profile Header Banner ────────────────────────────── -->
    <div class="app-card border-0 mb-4 overflow-hidden animate-up profile-header-banner" style="border-radius:24px;">
        <div class="profile-header-glow"></div>
        <div class="p-4 d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-4"
             style="position:relative;z-index:2;">
            <div class="d-flex align-items-center">
                <div class="position-relative">
                    <img id="profile-avatar-img" src="" alt="Avatar"
                         class="avatar-circle border border-3 shadow-lg profile-avatar-img" />
                    <div class="position-absolute bottom-0 end-0 rounded-circle d-flex align-items-center justify-content-center shadow-sm profile-cam-btn">
                        <i class="fas fa-camera" style="font-size:0.7rem;"></i>
                    </div>
                </div>
                <div class="ms-4">
                    <h4 class="fw-bold mb-1 text-white" id="profile-name-display">—</h4>
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <span class="badge fw-bold px-2 py-1 profile-tier-badge" id="profile-tier-badge">—</span>
                        <span class="small fw-medium" style="color:rgba(255,255,255,0.5);" id="profile-phone-display">—</span>
                    </div>
                </div>
            </div>
            <div class="rounded-4 px-4 py-3 d-flex flex-column align-items-md-end profile-pts-box">
                <small class="fw-bold mb-1" style="font-size:0.65rem;letter-spacing:1px;color:rgba(255,255,255,0.5);">S-POINTS TÍCH LŨY</small>
                <h3 class="fw-bold text-warning mb-0" id="profile-points-display">— <span style="font-size:1rem;font-weight:bold;">PTS</span></h3>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- ── Left Column: Profile Form + Password Form ─────── -->
        <div class="col-lg-6">

            <!-- Profile Details Card -->
            <div class="app-card border-0 shadow-sm p-4 mb-4 bg-white animate-up" style="border-radius:24px;">
                <div class="d-flex align-items-center mb-4">
                    <div class="rounded-4 p-3 me-3 d-flex align-items-center justify-content-center"
                         style="background:rgba(15,23,42,0.06);width:48px;height:48px;">
                        <i class="fas fa-user-edit fa-lg" style="color:var(--navy-dark);"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0" style="color:var(--navy-dark);">Hồ sơ cá nhân</h5>
                        <p class="text-muted mb-0 small">Cập nhật ảnh đại diện và thông tin liên hệ của bạn.</p>
                    </div>
                </div>

                <form id="profile-form" onsubmit="handleSaveProfile(event)">
                    <!-- Avatar presets -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted d-block mb-3" style="letter-spacing:0.5px;">CHỌN ẢNH ĐẠI DIỆN</label>
                        <div class="d-flex gap-3 flex-wrap" id="avatar-presets-row">
                            <!-- Rendered by profile.js -->
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted" style="letter-spacing:0.5px;">HỌ VÀ TÊN</label>
                        <div class="input-group glass-input-group bg-light">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-user"></i></span>
                            <input type="text" id="edit-name" class="form-control bg-transparent border-0 py-3 fw-semibold"
                                   style="font-size:0.92rem;color:var(--navy-dark);" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted" style="letter-spacing:0.5px;">SỐ ĐIỆN THOẠI</label>
                        <div class="input-group glass-input-group bg-light">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-phone"></i></span>
                            <input type="text" id="edit-phone" class="form-control bg-transparent border-0 py-3 fw-semibold"
                                   style="font-size:0.92rem;color:var(--navy-dark);" required />
                        </div>
                    </div>

                    <button type="submit" class="app-btn-primary shadow-none py-3 w-100" style="letter-spacing:0.5px;">
                        <i class="fas fa-save me-2"></i>LƯU HỒ SƠ CÁ NHÂN
                    </button>
                </form>
            </div>

            <!-- Change Password Card -->
            <div class="app-card border-0 shadow-sm p-4 mb-4 bg-white animate-up" style="border-radius:24px;">
                <div class="d-flex align-items-center mb-4">
                    <div class="rounded-4 p-3 me-3 d-flex align-items-center justify-content-center"
                         style="background:rgba(15,23,42,0.06);width:48px;height:48px;">
                        <i class="fas fa-shield-alt fa-lg" style="color:var(--navy-dark);"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0" style="color:var(--navy-dark);">Bảo mật tài khoản</h5>
                        <p class="text-muted mb-0 small">Thay đổi mật khẩu đăng nhập của bạn.</p>
                    </div>
                </div>

                <form id="password-form" onsubmit="handleSavePassword(event)">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted" style="letter-spacing:0.5px;">MẬT KHẨU HIỆN TẠI</label>
                        <div class="input-group glass-input-group bg-light" style="opacity:0.7;">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-lock"></i></span>
                            <input type="password" id="curr-password" class="form-control bg-transparent border-0 py-3 fw-semibold"
                                   value="12345678" disabled style="font-size:0.92rem;" />
                        </div>
                        <small class="text-muted d-block mt-1" style="font-size:0.65rem;">* Mật khẩu thử nghiệm mặc định</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted" style="letter-spacing:0.5px;">MẬT KHẨU MỚI</label>
                        <div class="input-group glass-input-group bg-light">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-key"></i></span>
                            <input type="password" id="new-password" class="form-control bg-transparent border-0 py-3 fw-semibold"
                                   placeholder="Nhập tối thiểu 6 ký tự" required style="font-size:0.92rem;" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted" style="letter-spacing:0.5px;">XÁC NHẬN MẬT KHẨU MỚI</label>
                        <div class="input-group glass-input-group bg-light">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-lock-open"></i></span>
                            <input type="password" id="confirm-password" class="form-control bg-transparent border-0 py-3 fw-semibold"
                                   placeholder="Nhập lại mật khẩu mới" required style="font-size:0.92rem;" />
                        </div>
                    </div>

                    <button type="submit" class="app-btn-primary shadow-none py-3 w-100" style="letter-spacing:0.5px;">
                        <i class="fas fa-key me-2"></i>CẬP NHẬT MẬT KHẨU
                    </button>
                </form>
            </div>
        </div>

        <!-- ── Right Column: Vehicles + Settings ─────────────── -->
        <div class="col-lg-6">

            <!-- Vehicles Card -->
            <div class="app-card border-0 shadow-sm p-4 mb-4 bg-white animate-up" style="border-radius:24px;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="d-flex align-items-center">
                        <div class="rounded-4 p-3 me-3 d-flex align-items-center justify-content-center"
                             style="background:rgba(15,23,42,0.06);width:48px;height:48px;">
                            <i class="fas fa-motorcycle fa-lg" style="color:var(--navy-dark);"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0" style="color:var(--navy-dark);">Phương tiện của tôi</h5>
                            <p class="text-muted mb-0 small">Quản lý xe để nhận diện LPR khi rửa xe.</p>
                        </div>
                    </div>
                    <button class="btn btn-sm fw-bold d-flex align-items-center gap-1"
                            style="background:rgba(14,165,233,0.08);border-radius:10px;padding:6px 14px;font-size:0.8rem;color:var(--cyan-electric);"
                            data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                        <i class="fas fa-plus"></i> Thêm xe
                    </button>
                </div>

                <!-- Empty state (shown when no vehicles) -->
                <div id="vehicles-empty" class="text-center py-5 border rounded-4 mb-2 bg-light" style="display:none;">
                    <div class="text-muted mb-3"><i class="fas fa-motorcycle fa-3x text-light"></i></div>
                    <h6 class="fw-bold mb-1" style="color:var(--navy-dark);">Chưa đăng ký xe nào</h6>
                    <p class="text-muted small mb-4 px-4 mx-auto" style="max-width:320px;">
                        Hãy thêm biển số xe máy của bạn để hệ thống LPR tại trạm tự động quét và phục vụ ngay lập tức.
                    </p>
                    <button class="app-btn-primary btn-sm py-2 px-4 w-auto shadow-none"
                            style="font-size:0.8rem;border-radius:12px;"
                            data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                        + ĐĂNG KÝ XE NGAY
                    </button>
                </div>

                <!-- Vehicle horizontal slide card deck (Giao diện garage trượt ngang hiện đại) -->
                <div class="garage-deck" id="vehicles-grid">
                    <!-- Rendered by profile.js -->
                </div>
            </div>

            <!-- App Settings Card -->
            <div class="app-card border-0 shadow-sm overflow-hidden mb-4 bg-white animate-up" style="border-radius:24px;">
                <div class="p-4 pb-2 border-bottom border-light">
                    <div class="d-flex align-items-center">
                        <div class="rounded-3 p-2 me-3 d-flex align-items-center justify-content-center"
                             style="background:rgba(15,23,42,0.06);width:36px;height:36px;">
                            <i class="fas fa-cog" style="color:var(--navy-dark);"></i>
                        </div>
                        <h6 class="fw-bold mb-0" style="color:var(--navy-dark);">Cài đặt & Trợ giúp</h6>
                    </div>
                </div>

                <div class="list-group list-group-flush">
                    <!-- Notification toggle -->
                    <div class="list-group-item d-flex justify-content-between align-items-center p-3 px-4 border-light">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-bell text-muted me-3" style="width:20px;"></i>
                            <span class="small fw-bold">Thông báo trạng thái xe</span>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="notif-toggle"
                                   checked onchange="handleNotifToggle()"
                                   style="background-color:var(--cyan-electric);border-color:var(--cyan-electric);" />
                        </div>
                    </div>
                    <!-- Support -->
                    <div class="list-group-item d-flex justify-content-between align-items-center p-3 px-4 border-light selectable-card"
                         style="cursor:pointer;" onclick="handleSupport()">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-question-circle text-muted me-3" style="width:20px;"></i>
                            <span class="small fw-bold">Trợ giúp & Phản hồi</span>
                        </div>
                        <i class="fas fa-chevron-right text-muted small"></i>
                    </div>
                    <!-- Logout -->
                    <div class="list-group-item d-flex justify-content-between align-items-center p-3 px-4 border-0 selectable-card"
                         style="cursor:pointer;" onclick="handleLogout()">
                        <div class="d-flex align-items-center text-danger">
                            <i class="fas fa-sign-out-alt me-3" style="width:20px;"></i>
                            <span class="small fw-bold">Đăng xuất tài khoản</span>
                        </div>
                        <i class="fas fa-chevron-right text-danger small"></i>
                    </div>
                </div>
            </div>

            <div class="text-center py-2 text-muted" style="font-size:0.75rem;font-weight:500;">
                Phiên bản 2.4.1 (AutoWash Pro)
            </div>
        </div>
    </div>
</div>

<!-- ── Add Vehicle Modal ──────────────────────────────────── -->
<div class="modal fade" id="addVehicleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered mx-auto" style="max-width:400px;">
        <div class="modal-content border-0 overflow-hidden" style="border-radius:24px;box-shadow:0 20px 40px rgba(0,0,0,0.15);">
            <div class="modal-header text-white border-0 px-4 pt-4 pb-3" style="background:var(--navy-dark);">
                <h6 class="fw-bold mb-0" style="color:var(--cyan-electric);">
                    <i class="fas fa-motorcycle me-2"></i>THÊM PHƯƠNG TIỆN MỚI
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 pt-3">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">BIỂN SỐ XE</label>
                    <input type="text" id="new-plate" class="form-control custom-input border-light bg-light"
                           placeholder="Ví dụ: 51H-123.45" style="border-radius:12px;" />
                    <small class="text-muted mt-1 d-block" style="font-size:0.68rem;">
                        Ví dụ format: 51G - 123.45 hoặc 59K1 - 999.99
                    </small>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">LOẠI XE (HÃNG & DÒNG XE)</label>
                    <select id="new-type" class="form-select custom-input border-light bg-light" style="border-radius:12px;">
                        <option value="Honda Vision">Honda Vision (Xe ga)</option>
                        <option value="SH Mode">SH Mode (Xe ga)</option>
                        <option value="Honda Wave">Honda Wave (Xe số)</option>
                        <option value="Exciter 150">Exciter 150 (Xe tay côn)</option>
                        <option value="Kawasaki Z1000">Kawasaki Z1000 (Phân khối lớn)</option>
                        <option value="Honda Lead">Honda Lead (Xe ga)</option>
                        <option value="Yamaha Grande">Yamaha Grande (Xe ga)</option>
                    </select>
                </div>
            </div>
            <div class="p-4 pt-0">
                <button class="app-btn-primary shadow-none py-3 w-100" onclick="handleAddVehicle()"
                        style="border-radius:12px;">
                    <i class="fas fa-save me-2"></i>ĐĂNG KÝ PHƯƠNG TIỆN
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/profile.js"></script>
}
