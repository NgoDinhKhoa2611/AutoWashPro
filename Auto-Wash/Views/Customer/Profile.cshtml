@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewBag.PageTitle = "Hồ sơ cá nhân";
    ViewBag.ActiveNav = "profile";
}

<div class="container-fluid p-0">

    <!-- ── Profile Header Banner ────────────────────────────── -->
    <div class="app-card border-0 mb-4 overflow-hidden animate-up profile-header-banner card-r-24" id="profile-header-banner">
        <div class="profile-header-glow"></div>
        <div class="p-4 d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-4 member-card-layer">
            <div class="d-flex align-items-center">
                <div class="position-relative">
                    <img id="profile-avatar-img-gg" src="" alt="Avatar"
                         class="avatar-circle border border-3 shadow-lg profile-avatar-img" />
                    <div class="position-absolute bottom-0 end-0 rounded-circle d-flex align-items-center justify-content-center shadow-sm profile-cam-btn">
                        <i class="fas fa-camera"></i>
                    </div>
                </div>
                <div class="ms-4">
                    <h4 class="fw-bold mb-1 text-white" id="profile-name-display">—</h4>
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <span class="badge fw-bold px-2 py-1 profile-tier-badge" id="profile-tier-badge">—</span>
                        <span class="small fw-medium profile-phone-text" id="profile-phone-display">—</span>
                    </div>
                </div>
            </div>
            <div class="rounded-4 px-4 py-3 d-flex flex-column align-items-md-end profile-pts-box">
                <small class="fw-bold mb-1 profile-pts-sub">S-POINTS TÍCH LŨY</small>
                <h3 class="fw-bold text-warning mb-0" id="profile-points-display">— <span class="profile-pts-span fw-bold">PTS</span></h3>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- ── Left Column: Profile Form + Password Form ─────── -->
        <div class="col-lg-6">

            <!-- Profile Details Card -->
            <div class="app-card border-0 shadow-sm p-4 mb-4 bg-white animate-up card-r-24">
                <div class="d-flex align-items-center mb-4">
                    <div class="rounded-4 p-3 me-3 d-flex align-items-center justify-content-center section-icon-box-lg section-icon-box-bg">
                        <i class="fas fa-user-edit fa-lg section-icon-color"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0 section-title">Hồ sơ cá nhân</h5>
                        <p class="text-muted mb-0 small">Cập nhật ảnh đại diện và thông tin liên hệ của bạn.</p>
                    </div>
                </div>

                <form id="profile-form" onsubmit="handleSaveProfile(event)">
                    <!-- Avatar presets -->
                    @* <div class="mb-4">
                        <label class="form-label small fw-bold text-muted d-block mb-3 form-label-spaced">CHỌN ẢNH ĐẠI DIỆN</label>
                        <div class="d-flex gap-3 flex-wrap" id="avatar-presets-row">
                            <!-- Rendered by profile.js -->
                        </div>
                    </div> *@

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted form-label-spaced">HỌ VÀ TÊN</label>
                        <div class="input-group glass-input-group bg-light">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-user"></i></span>
                            <input type="text" id="edit-name" class="form-control bg-transparent border-0 py-3 fw-semibold profile-input-text" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted form-label-spaced">SỐ ĐIỆN THOẠI</label>
                        <div class="input-group glass-input-group bg-light">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-phone"></i></span>
                            <input type="text" id="edit-phone" class="form-control bg-transparent border-0 py-3 fw-semibold profile-input-text" required />
                        </div>
                    </div>

                    <button type="submit" class="app-btn-primary shadow-none py-3 w-100 profile-save-btn">
                        <i class="fas fa-save me-2"></i>LƯU HỒ SƠ CÁ NHÂN
                    </button>
                </form>
            </div>

            <!-- Change Password Card -->
            <div class="app-card border-0 shadow-sm p-4 mb-4 bg-white animate-up card-r-24">
                <div class="d-flex align-items-center mb-4">
                    <div class="rounded-4 p-3 me-3 d-flex align-items-center justify-content-center section-icon-box-lg section-icon-box-bg">
                        <i class="fas fa-shield-alt fa-lg section-icon-color"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0 section-title">Bảo mật tài khoản</h5>
                        <p class="text-muted mb-0 small">Thay đổi mật khẩu đăng nhập của bạn.</p>
                    </div>
                </div>

                <form id="password-form" onsubmit="handleSavePassword(event)">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted form-label-spaced">MẬT KHẨU HIỆN TẠI</label>
                        <div class="input-group glass-input-group bg-light form-group-disabled">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-lock"></i></span>
                            <input type="password" id="curr-password" class="form-control bg-transparent border-0 py-3 fw-semibold profile-input-sm"
                                   value="12345678" disabled />
                        </div>
                        <small class="text-muted d-block mt-1 password-note">* Mật khẩu thử nghiệm mặc định</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted form-label-spaced">MẬT KHẨU MỚI</label>
                        <div class="input-group glass-input-group bg-light">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-key"></i></span>
                            <input type="password" id="new-password" class="form-control bg-transparent border-0 py-3 fw-semibold profile-input-sm"
                                   placeholder="Nhập tối thiểu 6 ký tự" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted form-label-spaced">XÁC NHẬN MẬT KHẨU MỚI</label>
                        <div class="input-group glass-input-group bg-light">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-lock-open"></i></span>
                            <input type="password" id="confirm-password" class="form-control bg-transparent border-0 py-3 fw-semibold profile-input-sm"
                                   placeholder="Nhập lại mật khẩu mới" required />
                        </div>
                    </div>

                    <button type="submit" class="app-btn-primary shadow-none py-3 w-100 profile-save-btn">
                        <i class="fas fa-key me-2"></i>CẬP NHẬT MẬT KHẨU
                    </button>
                </form>
            </div>
        </div>

        <!-- ── Right Column: Vehicles + Settings ─────────────── -->
        <div class="col-lg-6">

            <!-- Vehicles Card -->
            <div class="app-card border-0 shadow-sm p-4 mb-4 bg-white animate-up card-r-24">
                <div class="d-flex justify-content-between align-items-center mb-4 gap-2">
                    <div class="d-flex align-items-center flex-min-0">
                        <div class="rounded-4 p-3 me-3 d-flex align-items-center justify-content-center flex-shrink-0 section-icon-box-lg section-icon-box-bg">
                            <i class="fas fa-motorcycle fa-lg section-icon-color"></i>
                        </div>
                        <div class="min-w-0">
                            <h5 class="fw-bold mb-0 section-title profile-vehicle-title">Phương tiện của tôi</h5>
                            <p class="text-muted mb-0 small text-truncate">Quản lý xe để nhận diện LPR khi rửa xe.</p>
                        </div>
                    </div>
                    <button class="btn btn-sm fw-bold add-vehicle-btn"
                            data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                        <i class="fas fa-plus"></i>Thêm&nbsp;xe
                    </button>
                </div>

                <!-- Empty state (shown when no vehicles) -->
                <div id="vehicles-empty" class="text-center py-5 border rounded-4 mb-2 bg-light" style="display:none;">
                    <div class="text-muted mb-3"><i class="fas fa-motorcycle fa-3x text-light"></i></div>
                    <h6 class="fw-bold mb-1 section-title">Chưa đăng ký xe nào</h6>
                    <p class="text-muted small mb-4 px-4 mx-auto profile-empty-desc">
                        Hãy thêm biển số xe máy của bạn để hệ thống LPR tại trạm tự động quét và phục vụ ngay lập tức.
                    </p>
                    <button class="app-btn-primary btn-sm py-2 px-4 w-auto shadow-none profile-empty-btn"
                            data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                        + ĐĂNG KÝ XE NGAY
                    </button>
                </div>

                <!-- Vehicle horizontal slide card deck (Giao diện garage trượt ngang hiện đại) -->
                <div class="garage-deck" id="vehicles-grid">
                    <!-- Rendered by profile.js -->
                </div>
            </div>

            <!-- App Settings Card -->
            <div class="app-card border-0 shadow-sm overflow-hidden mb-4 bg-white animate-up card-r-24">
                <div class="p-4 pb-2 border-bottom border-light">
                    <div class="d-flex align-items-center">
                        <div class="rounded-3 p-2 me-3 d-flex align-items-center justify-content-center section-icon-box-sm section-icon-box-bg">
                            <i class="fas fa-cog section-icon-color"></i>
                        </div>
                        <h6 class="fw-bold mb-0 section-title">Cài đặt & Trợ giúp</h6>
                    </div>
                </div>

                <div class="list-group list-group-flush">
                    <!-- Notification toggle -->
                    <div class="list-group-item d-flex justify-content-between align-items-center p-3 px-4 border-light">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-bell text-muted me-3 settings-icon"></i>
                            <span class="small fw-bold">Thông báo trạng thái xe</span>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="notif-toggle"
                                   checked onchange="handleNotifToggle()" />
                        </div>
                    </div>
                    <!-- Support -->
                    <div class="list-group-item d-flex justify-content-between align-items-center p-3 px-4 border-light selectable-card"
                         onclick="handleSupport()">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-question-circle text-muted me-3 settings-icon"></i>
                            <span class="small fw-bold">Trợ giúp & Phản hồi</span>
                        </div>
                        <i class="fas fa-chevron-right text-muted small"></i>
                    </div>
                    <!-- Logout -->
                    <div class="list-group-item d-flex justify-content-between align-items-center p-3 px-4 border-0 selectable-card"
                         onclick="handleLogout()">
                        <div class="d-flex align-items-center text-danger">
                            <i class="fas fa-sign-out-alt me-3 settings-icon"></i>
                            <span class="small fw-bold">Đăng xuất tài khoản</span>
                        </div>
                        <i class="fas fa-chevron-right text-danger small"></i>
                    </div>
                </div>
            </div>

            <div class="text-center py-2 text-muted profile-version">
                Phiên bản 2.4.1 (AutoWash Pro)
            </div>
        </div>
    </div>
</div>

<!-- ── Add Vehicle Modal ──────────────────────────────────── -->
<div class="modal fade" id="addVehicleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered mx-auto modal-vehicle">
        <div class="modal-content border-0 overflow-hidden">
            <div class="modal-header text-white border-0 px-4 pt-4 pb-3">
                <h6 class="fw-bold mb-0 modal-vehicle-title">
                    <i class="fas fa-motorcycle me-2"></i>THÊM PHƯƠNG TIỆN MỚI
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 pt-3">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">BIỂN SỐ XE</label>
                    <input type="text" id="new-plate" class="form-control custom-input border-light bg-light input-rounded-sm"
                           placeholder="Ví dụ: 51H-123.45" />
                    <small class="text-muted mt-1 d-block password-note">
                        Ví dụ format: 51G - 123.45 hoặc 59K1 - 999.99
                    </small>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">LOẠI XE (HÃNG & DÒNG XE)</label>
                    <select id="new-type" class="form-select custom-input border-light bg-light input-rounded-sm">
                        <option value="Honda Vision">Honda Vision (Xe ga)</option>
                        <option value="SH Mode">SH Mode (Xe ga)</option>
                        <option value="Honda Wave">Honda Wave (Xe số)</option>
                        <option value="Exciter 150">Exciter 150 (Xe tay côn)</option>
                        <option value="Kawasaki Z1000">Kawasaki Z1000 (Phân khối lớn)</option>
                        <option value="Honda Lead">Honda Lead (Xe ga)</option>
                        <option value="Yamaha Grande">Yamaha Grande (Xe ga)</option>
                    </select>
                </div>
            </div>
            <div class="p-4 pt-0">
                <button class="app-btn-primary shadow-none py-3 w-100 input-rounded-sm" onclick="handleAddVehicle()">
                    <i class="fas fa-save me-2"></i>ĐĂNG KÝ PHƯƠNG TIỆN
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
<link rel="stylesheet" href="~/css/customer/profile.css" asp-append-version="true" />
}

@section Scripts {
<script src="~/js/profile.js"></script>
}
