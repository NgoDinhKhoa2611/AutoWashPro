@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewBag.PageTitle = "Tổng quan hoạt động";
    ViewBag.ActiveNav = "dashboard";
    /* Demo data — sau này thay bằng @Model hoặc @ViewBag từ Controller */
    var userName   = ViewBag.UserName   ?? "Lê Tuấn Kiệt";
    var points     = ViewBag.UserPoints ?? 550;
    var tier       = ViewBag.UserTier   ?? "Gold Member";
    var nextTier   = ViewBag.NextTier   ?? "Platinum";
    var remaining  = ViewBag.RemainingSpend ?? "250k";
    var vehicles   = 2;
}

<div class="container-fluid p-0">

    <!-- ── Greeting & Weather Concierge ───────────────────────── -->
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3 animate-up">
        <!-- Desktop-only Greeting -->
        <div class="d-none d-md-block">
            <h3 class="fw-bold mb-1 concierge-greeting-text" id="concierge-greeting">Xin chào, @userName!</h3>
            <p class="text-muted mb-0 small concierge-subtitle">Theo dõi tiến trình rửa xe, điểm tích lũy và đặc quyền thành viên của bạn.</p>
        </div>
        <!-- Mobile compact greeting -->
        <div class="d-block d-md-none w-100">
            <div class="d-flex align-items-center justify-content-between gap-2">
                <h4 class="fw-bold mb-0 text-dark concierge-greeting-mobile">Xin chào, @userName! 👋</h4>
                <div class="d-flex align-items-center gap-1 px-2 py-1 rounded-pill bg-white border concierge-weather-chip-mobile">
                    <span class="text-warning"><i class="fas fa-sun animate-spin-slow"></i></span>
                    <span class="fw-bold text-secondary">Rửa xe tốt!</span>
                </div>
            </div>
        </div>
        <!-- Wash Suitability Index Chip (Desktop only) -->
        <div class="d-none d-md-flex align-items-center gap-2 px-3 py-2 rounded-pill bg-white border shadow-sm concierge-weather-chip">
            <span class="d-flex align-items-center justify-content-center text-warning concierge-weather-icon"><i class="fas fa-sun animate-spin-slow"></i></span>
            <span class="fw-bold text-dark" id="concierge-weather">Thời tiết hôm nay lý tưởng để rửa xe! ☀️✨</span>
        </div>
    </div>

    <div class="row g-4">
        <!-- ── Left Column ─────────────────────────────────── -->
        <div class="col-lg-8">

            <!-- Membership Card (Giao diện kim loại phản chiếu 3D sang trọng) -->
            <div class="member-card tier-gold mb-4 member-card-3d" id="member-card">
                <div class="card-gloss-overlay"></div>
                <div class="d-flex justify-content-between align-items-start mb-2 member-card-layer">
                    <span class="tier-label m-0 fw-bold"><i class="fas fa-crown me-2"></i>@tier</span>
                    <div class="card-chip-icon">
                        <div class="chip-line"></div>
                        <div class="chip-line"></div>
                        <div class="chip-line"></div>
                    </div>
                </div>
                <div class="my-3 member-card-layer">
                    <h2 class="fw-bold text-white mb-0 fs-1 d-inline-block" id="dashboard-points">@points</h2>
                    <span class="ms-2 fw-bold text-cyan member-card-pts-label">PTS</span>
                    <p class="text-white opacity-50 mb-0 member-card-pts-sub">S-MEMBER LOYALTY POINTS</p>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3 member-card-layer member-card-footer">
                    <div>
                        <small class="member-card-meta-label">HẠNG TIẾP THEO</small>
                        <div class="fw-bold text-cyan member-card-tier-value" id="dashboard-next-tier">@nextTier — còn @remaining</div>
                    </div>
                    <div class="text-end">
                        <small class="member-card-meta-label">MÃ THÀNH VIÊN</small>
                        <div class="fw-bold text-white member-card-code-value" id="dashboard-card-code">AW-2026-GOLD</div>
                    </div>
                </div>
            </div>

            <!-- ── Quick Action Capsules Carousel ────────────────────── -->
            <div class="mb-4 animate-up anim-delay-1">
                <div class="d-flex gap-2 overflow-auto pb-2 no-scrollbar">
                    <a href="/Customer/Booking" class="btn btn-sm px-4 py-2 rounded-pill border-0 shadow-sm d-inline-flex align-items-center gap-2 bg-white quick-action-btn">
                        <div class="d-flex align-items-center justify-content-center rounded-circle text-white quick-action-icon qa-icon-booking"><i class="fas fa-calendar-alt small"></i></div>
                        Đặt lịch rửa xe
                    </a>
                    <a href="/Customer/Loyalty" class="btn btn-sm px-4 py-2 rounded-pill border-0 shadow-sm d-inline-flex align-items-center gap-2 bg-white quick-action-btn">
                        <div class="d-flex align-items-center justify-content-center rounded-circle text-white quick-action-icon qa-icon-loyalty"><i class="fas fa-gift small"></i></div>
                        Đổi quà ưu đãi
                    </a>
                    <a href="/Customer/History" class="btn btn-sm px-4 py-2 rounded-pill border-0 shadow-sm d-inline-flex align-items-center gap-2 bg-white quick-action-btn">
                        <div class="d-flex align-items-center justify-content-center rounded-circle text-white quick-action-icon qa-icon-history"><i class="fas fa-history small"></i></div>
                        Lịch sử của tôi
                    </a>
                    <a href="/Customer/Profile" class="btn btn-sm px-4 py-2 rounded-pill border-0 shadow-sm d-inline-flex align-items-center gap-2 bg-white quick-action-btn">
                        <div class="d-flex align-items-center justify-content-center rounded-circle text-white quick-action-icon qa-icon-profile"><i class="fas fa-user small"></i></div>
                        Cài đặt tài khoản
                    </a>
                </div>
            </div>

            <!-- Active Booking / Empty State (điều khiển bằng JS đọc localStorage) -->
            <div id="empty-state-block" class="empty-state-container mb-4 animate-up" style="display:none;">
                <div class="empty-state-icon">
                    <i class="fas fa-shower fa-2x"></i>
                </div>
                <h5 class="fw-bold mb-2 empty-state-title">Bạn chưa sử dụng dịch vụ nào</h5>
                <p class="text-muted small mb-4 empty-state-desc">
                    Đăng ký đặt lịch rửa xe ngay để được xếp vào hàng đợi phục vụ tự động thông minh.
                </p>
                <a href="/Customer/Booking"
                   class="app-btn-primary py-3 px-5 w-auto shadow-none text-decoration-none d-inline-flex align-items-center gap-2 empty-state-btn">
                    ĐẶT LỊCH NGAY <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <!-- Active Booking Block -->
            <div id="active-booking-block" class="app-card border-0 p-4 shadow-sm bg-white mb-4 animate-up card-r-24" style="display:none;">
                <!-- Rendered dynamically by dashboard.js -->
            </div>

            <!-- Telemetry Stats Grid -->
            <div class="row g-2 g-md-3 mb-4 animate-up anim-delay-2">
                <!-- Stats 1: My Garage with Plate Tags -->
                <div class="col-4 col-sm-4">
                    <div class="app-card border-0 p-3 shadow-sm bg-white h-100 d-flex flex-column justify-content-between card-r-20">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <i class="fas fa-motorcycle text-cyan mb-2 fa-lg"></i>
                                <div class="text-muted small fw-bold d-none d-md-block stat-label">XE CỦA TÔI</div>
                            </div>
                            <span class="badge rounded bg-light text-dark fw-bold px-2 py-1 d-none d-sm-inline stat-badge-count" id="stat-vehicles-count">@vehicles xe</span>
                        </div>
                        <div class="mt-2">
                            <div class="d-none d-md-flex flex-wrap gap-1" id="stat-garage-plates">
                                <!-- Rendered dynamically by dashboard.js as small glass plates -->
                            </div>
                            <div class="d-block d-md-none text-dark fw-bold stat-plates-mobile" id="stat-garage-plates-mobile">
                                <!-- Mobile compact plate placeholder -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats 2: Reward Points with Progress bar -->
                <div class="col-4 col-sm-4">
                    <div class="app-card border-0 p-3 shadow-sm bg-white h-100 d-flex flex-column justify-content-between card-r-20">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <i class="fas fa-coins text-warning mb-2 fa-lg"></i>
                                <div class="text-muted small fw-bold d-none d-md-block stat-label">ĐIỂM THƯỞNG</div>
                            </div>
                        </div>
                        <div class="mt-2">
                            <h4 class="fw-bold mb-0 text-dark stat-primary-value" id="stat-points">@points <span class="d-none d-md-inline stat-badge-count">PTS</span></h4>
                            <div class="progress rounded-pill bg-light mt-2 d-none d-md-flex stat-progress-track">
                                <div class="progress-bar bg-warning rounded-pill" role="progressbar" style="width: 65%;" id="stat-points-progress"></div>
                            </div>
                            <small class="d-none d-md-block mt-1 stat-expiry-warning" id="stat-expiry-warning">
                                <i class="fas fa-exclamation-circle me-1"></i><span id="stat-expiry-text"></span>
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Stats 3: VIP Tier Medal Card -->
                <div class="col-4 col-sm-4">
                    <div class="app-card border-0 p-3 shadow-sm bg-white h-100 d-flex flex-column justify-content-between card-r-20">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-crown text-primary mb-2 fa-lg stat-crown-purple"></i>
                                <div class="text-muted small fw-bold d-none d-md-block stat-label">VIP TIER</div>
                            </div>
                            <div class="d-none d-md-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10 text-warning stat-tier-medal" id="stat-tier-medal">
                                <i class="fas fa-medal"></i>
                            </div>
                        </div>
                        <div class="mt-2">
                            <h4 class="fw-bold mb-0 text-dark stat-primary-value" id="stat-tier">
                                @tier.Replace(" Member", "")
                            </h4>
                            <small class="text-muted d-none d-md-block stat-tier-desc" id="stat-tier-desc">Đặc quyền đặt lịch ưu tiên</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Right Column ────────────────────────────────── -->
        <div class="col-lg-4">
            <!-- Booking CTA Banner -->
            <div class="mb-4 animate-up anim-delay-2">
                <div class="app-card border-0 d-flex flex-column justify-content-between p-4 shadow-lg booking-cta-card">
                    <div>
                        <h4 class="fw-bold mb-1 text-cyan">Rửa Xe Đặt Lịch Ngay</h4>
                        <p class="small mb-0 booking-cta-subtitle">
                            Đặt chỗ trước chỉ mất 30 giây để được sắp xếp vào hàng đợi ưu tiên VIP của AutoWash Pro.
                        </p>
                    </div>
                    <a href="/Customer/Booking"
                       class="app-btn-primary py-3 w-100 shadow-none mt-3 text-decoration-none d-flex align-items-center justify-content-center gap-2 card-r-14">
                        ĐẶT LỊCH NGAY <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>

            <!-- Quick Categories -->
            <div class="mb-4 animate-up anim-delay-3">
                <div class="row g-2">
                    <div class="col-6">
                        <a href="/Customer/History"
                           class="app-card border-0 shadow-sm p-3 h-100 d-flex flex-column justify-content-between text-decoration-none animate-up quick-cat-card">
                            <div class="d-flex justify-content-between align-items-start">
                                <i class="fas fa-history text-cyan mb-2 fa-lg"></i>
                                <i class="fas fa-chevron-right text-muted small mt-1 category-chevron"></i>
                             </div>
                             <div class="mt-2">
                                 <h4 class="fw-bold mb-0 text-dark category-title">Lịch sử</h4>
                             </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/Customer/Loyalty"
                           class="app-card border-0 shadow-sm p-3 h-100 d-flex flex-column justify-content-between text-decoration-none animate-up quick-cat-card">
                            <div class="d-flex justify-content-between align-items-start">
                                <i class="fas fa-gift text-warning mb-2 fa-lg"></i>
                                <i class="fas fa-chevron-right text-muted small mt-1 category-chevron"></i>
                             </div>
                             <div class="mt-2">
                                 <h4 class="fw-bold mb-0 text-dark category-title">Ưu đãi VIP</h4>
                             </div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Concierge Notifications Timeline -->
            <div class="app-card border-0 shadow-sm p-4 bg-white animate-up mb-4 card-r-24 anim-delay-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0 notif-widget-title">
                        <i class="far fa-bell text-cyan me-2"></i>Dòng thời gian hoạt động
                    </h6>
                    <button class="btn btn-link p-0 text-cyan small text-decoration-none fw-bold notif-widget-read-btn"
                            onclick="markAllRead()">
                        Đọc hết
                    </button>
                </div>
                <!-- Timeline stream -->
                <div class="concierge-feed d-flex flex-column gap-3 notif-feed-scroll" id="notif-widget-list">
                    <div class="feed-timeline-line"></div>
                    <!-- Feed items dynamically rendered by dashboard.js as timeline concierge dots -->
                    <div class="text-center py-4 text-muted small">Không có thông báo hoạt động nào</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
<link rel="stylesheet" href="~/css/customer/dashboard.css" asp-append-version="true" />
}

@section Scripts {
<script src="~/js/dashboard.js"></script>
}
