@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewBag.PageTitle = "Đặc quyền VIP & Loyalty";
    ViewBag.ActiveNav = "loyalty";
}

<div class="container-fluid p-0 animate-up">
    <div class="row g-4">

        <!-- ── Left Column ─────────────────────────────────── -->
        <div class="col-lg-8 order-2 order-lg-1">

            <!-- Tier Simulator -->
            <div class="app-card border-0 shadow-sm p-4 mb-4 bg-white card-r-24">
                <div class="d-flex align-items-center mb-3">
                    <div class="p-2 me-3 d-flex align-items-center justify-content-center section-icon-box-md section-icon-box-bg">
                        <i class="fas fa-crown fa-lg section-icon-color"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0 section-title">Bộ giả lập phân cấp thành viên</h5>
                        <small class="text-muted">Chọn hạng thành viên để kiểm tra và thay đổi các chính sách ưu đãi.</small>
                    </div>
                </div>

                <div class="row g-2">
                    <div class="col-6 col-md-3">
                        <div onclick="changeTier('Standard Member')"
                             class="p-3 text-center fw-bold selectable-card h-100 border border-light bg-light loyalty-tier-btn"
                             id="tier-btn-standard">
                            <i class="fas fa-user text-secondary d-block fs-4 mb-2"></i>
                            <span class="loyalty-tier-label">MEMBER</span>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div onclick="changeTier('Silver Member')"
                             class="p-3 text-center fw-bold selectable-card h-100 border border-light bg-light loyalty-tier-btn"
                             id="tier-btn-silver">
                            <i class="fas fa-medal text-muted d-block fs-4 mb-2"></i>
                            <span class="loyalty-tier-label">SILVER</span>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div onclick="changeTier('Gold Member')"
                             class="p-3 text-center fw-bold selectable-card h-100 border border-light bg-light loyalty-tier-btn"
                             id="tier-btn-gold">
                            <i class="fas fa-award text-warning d-block fs-4 mb-2"></i>
                            <span class="loyalty-tier-label">GOLD</span>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div onclick="changeTier('Platinum Member')"
                             class="p-3 text-center fw-bold selectable-card h-100 border border-light bg-light loyalty-tier-btn"
                             id="tier-btn-platinum">
                            <i class="fas fa-crown text-cyan d-block fs-4 mb-2"></i>
                            <span class="loyalty-tier-label">PLATINUM</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Rewards Header + Filter -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 mt-4 gap-2">
                <h5 class="fw-bold mb-0 loyalty-rewards-title">
                    Ưu đãi đổi thưởng (<span id="rewards-count">12</span>)
                </h5>
                <button onclick="showLoyaltyRules()"
                        class="btn btn-link p-0 text-cyan small text-decoration-none fw-bold">
                    Quy định tích điểm <i class="fas fa-question-circle ms-1"></i>
                </button>
            </div>

            <!-- Category Filter Pills -->
            <div class="d-flex gap-2 overflow-auto pb-3 no-scrollbar mb-4">
                <button onclick="filterCategory('Tất cả')"
                        class="btn btn-sm px-4 rounded-pill py-2 border-0 app-btn-primary w-auto text-dark loyalty-filter-btn"
                        id="cat-all">
                    Tất cả
                </button>
                <button onclick="filterCategory('Giảm giá')"
                        class="btn btn-sm px-4 rounded-pill py-2 border-0 app-card w-auto shadow-sm text-muted bg-white loyalty-filter-btn"
                        id="cat-discount">
                    Giảm giá
                </button>
                <button onclick="filterCategory('Dịch vụ')"
                        class="btn btn-sm px-4 rounded-pill py-2 border-0 app-card w-auto shadow-sm text-muted bg-white loyalty-filter-btn"
                        id="cat-service">
                    Dịch vụ
                </button>
                <button onclick="filterCategory('Quà tặng')"
                        class="btn btn-sm px-4 rounded-pill py-2 border-0 app-card w-auto shadow-sm text-muted bg-white loyalty-filter-btn"
                        id="cat-gift">
                    Quà tặng
                </button>
                <button onclick="filterCategory('Combo đặc biệt')"
                        class="btn btn-sm px-4 rounded-pill py-2 border-0 app-card w-auto shadow-sm text-muted bg-white loyalty-filter-btn"
                        id="cat-combo">
                    Combo đặc biệt
                </button>
                <button onclick="filterCategory('Ưu đãi sinh nhật')"
                        class="btn btn-sm px-4 rounded-pill py-2 border-0 app-card w-auto shadow-sm text-muted bg-white loyalty-filter-btn"
                        id="cat-birthday">
                    Ưu đãi sinh nhật
                </button>
            </div>

            <!-- Rewards Grid -->
            <div class="row g-3" id="rewards-grid">
                <!-- Rendered by loyalty.js -->
            </div>
        </div>

        <!-- ── Right Column: Member Card + Perks ──────────── -->
        <div class="col-lg-4 order-1 order-lg-2">
            <div class="position-sticky loyalty-sticky-col">
                <!-- Member Card Preview -->
                <div class="mb-4" id="loyalty-member-card">
                    <!-- Rendered by loyalty.js -->
                </div>

                <!-- VIP Perks Detail Card -->
                <div class="app-card border-0 shadow-sm p-4 bg-white card-r-24">
                    <h6 class="fw-bold mb-3 border-bottom pb-2 loyalty-perks-title">
                        <i class="fas fa-star-of-life text-cyan me-2"></i>
                        Đặc quyền hạng <span id="tier-perks-label">Gold</span>
                    </h6>
                    <ul class="list-unstyled d-flex flex-column gap-3 mb-0 text-muted loyalty-perks-list">
                        <li class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div id="perk-queue">
                                <strong>Ưu tiên hàng đợi:</strong> Bypass hàng rửa xe thường. Vào thẳng ô rửa VIP.
                            </div>
                        </li>
                        <li class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div id="perk-multiplier">
                                <strong>Hệ số tích điểm:</strong> Nhân hệ số x1.2 điểm thưởng.
                            </div>
                        </li>
                        <li class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div id="perk-birthday">
                                <strong>Quà sinh nhật:</strong> Tặng 01 combo cao cấp rửa xe + vệ sinh sên miễn phí vào tháng sinh nhật.
                            </div>
                        </li>
                    </ul>
                </div>

                <!-- Points Expiry Card -->
                <div class="app-card border-0 shadow-sm p-4 bg-white card-r-24 mt-4">
                    <h6 class="fw-bold mb-3 border-bottom pb-2 loyalty-perks-title">
                        <i class="fas fa-hourglass-half text-warning me-2"></i>
                        Hạn sử dụng điểm thưởng
                    </h6>
                    <div id="expiry-batches" class="d-flex flex-column gap-2">
                        <!-- Rendered by loyalty.js -->
                    </div>
                    <small class="text-muted d-block mt-3 loyalty-expiry-note">
                        * Điểm tích lũy hết hạn sau <strong>12 tháng</strong> kể từ ngày giao dịch.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Redeem Confirm Modal ───────────────────────────────── -->
<div id="redeem-modal-overlay" class="confirm-modal-backdrop" style="display:none;"
     onclick="closeRedeemModal()">
    <div class="confirm-modal-card animate-confirm-in" onclick="event.stopPropagation()">
        <div id="redeem-modal-content">
            <!-- Rendered by loyalty.js -->
        </div>
    </div>
</div>

@section Styles {
<link rel="stylesheet" href="~/css/customer/loyalty.css" asp-append-version="true" />
}

@section Scripts {
<script src="~/js/loyalty.js"></script>
}
